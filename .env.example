ASPNETCORE_ENVIRONMENT=Development

DATABASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=aipromo;Username=postgres;Password=postgres

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_INSTANCE_NAME=aipromo:

RABBITMQ_CONNECTION_STRING=amqp://rabbitmq:5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

JWT_SECRET=replace-with-strong-secret
JWT_ISSUER=aipromo
JWT_AUDIENCE=aipromo-client
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=                                               
FACEBOOK_CLIENT_ID=
FACEBOOK_ANDROID_CLIENT_ID=

SMTP_SERVER=
SMTP_PORT=587
SENDER_EMAIL=
SENDER_PASSWORD=

EMBEDDING_REQUEST_QUEUE=embedding-request
EMBEDDING_RESPONSE_QUEUE=embedding-response
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_BASE_URL=http://embedding-api:8001

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_USE_HTTPS=false
QDRANT_API_KEY=

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

BACKEND_API_PORT=

# ─────────────────────────────────────────────────────────────
# HTTP API Configuration (Testing/Swagger)
# ─────────────────────────────────────────────────────────────
ENABLE_HTTP_API=true
HTTP_HOST=localhost
HTTP_PORT=8001

# ─────────────────────────────────────────────────────────────
# Model Configuration
# ─────────────────────────────────────────────────────────────
MODEL_NAME=bge-small-en-v1.5
MODEL_PATH=models/bge-small-en-v1.5

# ─────────────────────────────────────────────────────────────
# Processing Configuration
# ─────────────────────────────────────────────────────────────
BATCH_SIZE=32
NORMALIZE_EMBEDDINGS=true
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# Retry Configuration
# ─────────────────────────────────────────────────────────────
MAX_RETRIES=10
RETRY_DELAY=2.0
RECONNECT_INTERVAL=30