# =============================================================================
# AIPromo - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real secrets to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# ASP.NET Core Environment
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YourSecurePassword123!
POSTGRES_DB=AIPromo
POSTGRES_EXPOSE_PORT=5432
DATABASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=AIPromo;Username=postgres;Password=YourSecurePassword123!;SSL Mode=Disable;Trust Server Certificate=true

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YourRedisPassword123!
REDIS_INSTANCE_NAME=AIPromo
REDIS_EXPOSE_PORT=6379
REDIS_INSIGHT_PORT=5540

# -----------------------------------------------------------------------------
# RabbitMQ Message Broker
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=YourRabbitMQPassword123!
RABBITMQ_MGMT_PORT=15672
RABBITMQ_CONNECTION_STRING=amqp://admin:YourRabbitMQPassword123!@rabbitmq:5672

# -----------------------------------------------------------------------------
# MinIO Object Storage
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=YourMinIOAccessKey123
MINIO_SECRET_KEY=YourMinIOSecretKey123!
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Qdrant Vector Database
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_EXPOSE_PORT=6333
QDRANT_API_KEY=YourQdrantApiKey123!
QDRANT_USE_HTTPS=false

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=YourSuperSecretJWTKeyThatIsAtLeast32CharactersLong!
JWT_ISSUER=AIPromo
JWT_AUDIENCE=AIPromo
JWT_EXPIRY_MINUTES=100
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# -----------------------------------------------------------------------------
# Google Gemini AI
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# OpenRouter AI
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=black-forest-labs/flux.2-pro

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# Facebook OAuth
# -----------------------------------------------------------------------------
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_ANDROID_CLIENT_ID=your-facebook-android-client-id

# -----------------------------------------------------------------------------
# Gmail / SMTP Configuration
# -----------------------------------------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-specific-password

# -----------------------------------------------------------------------------
# Embedding Service (Python)
# -----------------------------------------------------------------------------
EMBEDDING_REQUEST_QUEUE=embedding.requests
EMBEDDING_RESPONSE_QUEUE=embedding.responses
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_BASE_URL=http://embedding-generator:8001
EMBEDDING_GENERATOR_PORT=5100
MODEL_NAME=bge-small-en-v1.5
BATCH_SIZE=32
NORMALIZE_EMBEDDINGS=true
LOG_LEVEL=INFO
MAX_RETRIES=10
RETRY_DELAY=2.0
RECONNECT_INTERVAL=30

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
BACKEND_API_PORT=5000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL_DEFAULT=Information
LOG_LEVEL_MICROSOFT=Warning
LOG_LEVEL_EF=Warning
LOG_LEVEL_QUARTZ=Warning
