# ─────────────────────────────────────────────────────────────
# General Configuration
# ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
LOG_LEVEL_DEFAULT=Information
LOG_LEVEL_MICROSOFT=Warning
LOG_LEVEL_EF=Warning
LOG_LEVEL_QUARTZ=Warning

# ─────────────────────────────────────────────────────────────
# Backend API Port (Host Machine)
# ─────────────────────────────────────────────────────────────
BACKEND_API_PORT=5000

# ─────────────────────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=AIPromo123
POSTGRES_DB=AIPromo
POSTGRES_EXPOSE_PORT=5432
# Connection string for the .NET container to talk to the DB container
DATABASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=AIPromo;Username=postgres;Password=AIPromo123

# ─────────────────────────────────────────────────────────────
# Redis Cache
# ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=AIPromo123
REDIS_INSTANCE_NAME=AIPromo:
REDIS_EXPOSE_PORT=6379
REDIS_INSIGHT_PORT=5540

# ─────────────────────────────────────────────────────────────
# RabbitMQ Message Broker
# ─────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin
# Connection string used by the .NET Backend
RABBITMQ_CONNECTION_STRING=rabbitmq

# ─────────────────────────────────────────────────────────────
# JWT Configuration
# ─────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-very-long-and-strong-secret-key
JWT_ISSUER=aipromo
JWT_AUDIENCE=aipromo-client
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─────────────────────────────────────────────────────────────
# LLM Providers (Gemini & OpenRouter)
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# OAuth (Google & Facebook)
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
FACEBOOK_CLIENT_ID=
FACEBOOK_ANDROID_CLIENT_ID=

# ─────────────────────────────────────────────────────────────
# Gmail / SMTP Configuration
# ─────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=
SENDER_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Embedding Service (Python)
# ─────────────────────────────────────────────────────────────
EMBEDDING_GENERATOR_PORT=5100
EMBEDDING_REQUEST_QUEUE=embedding-request
EMBEDDING_RESPONSE_QUEUE=embedding-response
EMBEDDING_TIMEOUT_SECONDS=30
# Used by .NET to call Python via HTTP
EMBEDDING_BASE_URL=http://embedding-generator:8001

# Python Specific Logic
MODEL_NAME=bge-small-en-v1.5
BATCH_SIZE=32
NORMALIZE_EMBEDDINGS=true
MAX_RETRIES=10
RETRY_DELAY=2.0
RECONNECT_INTERVAL=30

# ─────────────────────────────────────────────────────────────
# Qdrant Vector Database
# ─────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_EXPOSE_PORT=6333
QDRANT_USE_HTTPS=false
QDRANT_API_KEY=

# ─────────────────────────────────────────────────────────────
# MinIO Object Storage
# ─────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=aipromo
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false
STORAGE_PUBLIC_URL=http://localhost:9000/aipromo
MINIO_CONSOLE_PORT=9001

