{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Outbox": {
    "IntervalInSeconds": 5,
    "BatchSize": 30,
    "MaxRetryCount": 3
  },
  "Inbox": {
    "IntervalInSeconds": 5,
    "BatchSize": 20,
    "RetentionDays": 7,
    "MaxRetryCount": 3
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=AIPromo;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "AllowedHosts": "*"
}
