# ─────────────────────────────────────────────────────────────
# RabbitMQ Configuration (Production)
# ─────────────────────────────────────────────────────────────
# Use 'localhost' for local development, 'rabbitmq' for Docker
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin
REQUEST_QUEUE=embedding.requests
RESPONSE_QUEUE=embedding.responses

# ─────────────────────────────────────────────────────────────
# HTTP API Configuration (Testing/Swagger)
# ─────────────────────────────────────────────────────────────
ENABLE_HTTP_API=true
HTTP_HOST=http://localhost/
HTTP_PORT=8001

# ─────────────────────────────────────────────────────────────
# Model Configuration
# ─────────────────────────────────────────────────────────────
MODEL_NAME=bge-small-en-v1.5
MODEL_PATH=models/bge-small-en-v1.5

# ─────────────────────────────────────────────────────────────
# Processing Configuration
# ─────────────────────────────────────────────────────────────
BATCH_SIZE=32
NORMALIZE_EMBEDDINGS=true
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# Retry Configuration
# ─────────────────────────────────────────────────────────────
MAX_RETRIES=10
RETRY_DELAY=2.0
RECONNECT_INTERVAL=30