# ============================================
# AIPromo - Development Environment Variables
# ============================================
# ⚠️ IMPORTANT: Copy this file to terraform.tfvars and fill in your actual values
# NEVER commit terraform.tfvars to git (it's in .gitignore)
# ============================================

# ─────────────────────────────────────────────────────────────
# AWS & Infrastructure
# ─────────────────────────────────────────────────────────────
aws_region        = "ap-southeast-1"
project           = "aipromo"
environment       = "dev"
vpc_cidr          = "10.0.0.0/16"
ec2_instance_type = "t3.medium"
ec2_key_name      = "your-ec2-key-name"  # ⚠️ CHANGE: Your EC2 SSH key name
rds_instance_class = "db.t3.micro"

# ─────────────────────────────────────────────────────────────
# Domain & DNS
# ─────────────────────────────────────────────────────────────
domain_name   = "yourdomain.com"  # ⚠️ CHANGE: Your actual domain
api_subdomain = "api"

# ─────────────────────────────────────────────────────────────
# Database (RDS PostgreSQL)
# ─────────────────────────────────────────────────────────────
db_name     = "aipromo"
db_username = "aipromo"
db_password = "YourStrongRDSPassword123!"  # ⚠️ CHANGE: Strong password

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
redis_pass = "YourStrongRedisPassword123!"  # ⚠️ CHANGE: Strong password

# ─────────────────────────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────────────────────────
rabbitmq_user = "aipromo"
rabbitmq_pass = "YourStrongRabbitMQPassword123!"  # ⚠️ CHANGE: Strong password

# ─────────────────────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────────────────────
jwt_secret = "YourSuperLongAndStrongJWTSecretKeyHere-Minimum32Characters!"  # ⚠️ CHANGE: Very strong secret

# ─────────────────────────────────────────────────────────────
# Google OAuth (Optional - for Google Login)
# ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
google_client_id = ""  # ⚠️ Optional: Fill if using Google OAuth

# ─────────────────────────────────────────────────────────────
# Email / SMS (Gmail SMTP - for OTP & Notifications)
# ─────────────────────────────────────────────────────────────
# Get App Password from: https://myaccount.google.com/apppasswords
smtp_server      = "smtp.gmail.com"
smtp_port        = 587
sender_email     = ""  # ⚠️ Optional: Your Gmail address
sender_password  = ""  # ⚠️ Optional: Gmail App Password (16 chars)

# ─────────────────────────────────────────────────────────────
# VNPay Payment Gateway (CRITICAL for production)
# ─────────────────────────────────────────────────────────────
# Get from: https://sandbox.vnpayment.vn (testing) or https://merchant.vnpay.vn (production)
vnpay_url         = "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
vnpay_tmn_code    = ""  # ⚠️ REQUIRED: Your VNPay Terminal Code
vnpay_hash_secret = ""  # ⚠️ REQUIRED: Your VNPay Hash Secret
vnpay_return_url  = "https://aipromo.online/payment/callback"

# ─────────────────────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────────────────────
# Add your frontend URLs here (max 6 origins supported)
cors_allowed_origins = [
  "https://aipromo.online",
  "https://www.aipromo.online",
  "http://localhost:5500",      # Local dev
  "http://127.0.0.1:5500",      # Local dev
]
cors_allow_any_origin = false  # ⚠️ NEVER set true in production!

# ─────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────
# Restrict SSH access to your team IPs (CIDR format)
allowed_cidr = ["0.0.0.0/0"]  # ⚠️ CHANGE: Restrict to your IP, e.g., ["1.2.3.4/32"]
